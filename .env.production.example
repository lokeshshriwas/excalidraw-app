# ==============================================
# Excalidraw Production Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# Docker Hub Configuration
DOCKERHUB_USERNAME=johndoe

# Database Configuration
DB_USER=xxxxxx
DB_PASSWORD=xxxxx
DB_NAME=xxxxxx

# JWT Secret - Generate a strong random string
# You can generate one with: openssl rand -base64 32
JWT_SECRET=xxxxxxxxxxxx

# Domain Configuration (replace with your domain)
DOMAIN=example.com

# ==============================================
# Frontend Environment Variables (BUILD TIME)
# ==============================================
# These are embedded into the frontend bundle at build time
NEXT_PUBLIC_WS_URL=wss://example.comws
NEXT_PUBLIC_BASE_URL=https://example.com/v1
NEXT_PUBLIC_RAZORPAY_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend OAuth (for client-side OAuth flow initiation)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_GITHUB_CLIENT_ID=xxxxxxxxxxxxxxxxx

# ==============================================
# Backend Environment Variables (RUNTIME)
# ==============================================
# CORS Origins (comma-separated list)
CORS_ORIGINS=https://example.com

# Backend Base URL
BASE_URL=https://exmaple.com/v1

# Razorpay (Backend)
RAZORPAY_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# OAuth Secrets (Backend - for token exchange and validation)
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxx-xxxxxxxxxxxx--xxxxxxxxx
GITHUB_CLIENT_ID=xxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
