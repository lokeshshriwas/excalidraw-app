# ==============================================
# Excalidraw Production Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# Docker Hub Configuration
DOCKERHUB_USERNAME=your_dockerhub_username

# Database Configuration
DB_USER=excalidraw
DB_PASSWORD=your_secure_password_here
DB_NAME=excalidraw

# JWT Secret - Generate a strong random string
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Domain Configuration (replace with your domain)
DOMAIN=your-domain.com

# CORS Origins (comma-separated list)
CORS_ORIGINS=https://your-domain.com

# Backend Base URL
BASE_URL=https://your-domain.com/v1

# Razorpay Configuration (Test Mode)
# Get test keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret

# OAuth Configuration (Optional - Update redirect URIs in provider consoles)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
